# Multi-MCP — Environment Variables Example
# Copy this file to .env and fill in REAL values.
# NEVER commit .env with real values.

# Server settings
MULTI_MCP_HOST=0.0.0.0
MULTI_MCP_PORT=8765
MULTI_MCP_ENV=dev

# Secret store location (default: .secrets/)
# MULTI_MCP_SECRETS_DIR=.secrets

# Config directory (default: config/)
# MULTI_MCP_CONFIG_DIR=config

# Log directories (default: logs/audit, logs/execution)
# MULTI_MCP_AUDIT_LOG_DIR=logs/audit
# MULTI_MCP_EXEC_LOG_DIR=logs/execution
